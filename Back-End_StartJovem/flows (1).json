        "z": "c6c1498fd7368b4d",
        "name": "Formatar Array",
        "func": "const dados = [0,0,0,0,0,0,0];\nconst diasMap = {'Segunda':0,'Terça':1,'Quarta':2,'Quinta':3,'Sexta':4,'Sábado':5,'Domingo':6};\n\nif(msg.payload && msg.payload.length > 0){\n    msg.payload.forEach(item => {\n        const idx = diasMap[item.dia_semana];\n        if(idx !== undefined) dados[idx] = item.minutos;\n    });\n}\n\nmsg.payload = dados;\nreturn msg;",
