        "name": "Buscar Produtividade",
        "func": "const id = msg.req.params.id;\nmsg.topic = \"SELECT dia_semana, minutos FROM produtividade WHERE aprendiz_id = ? AND data_registro >= DATE_SUB(CURDATE(), INTERVAL 7 DAY)\";\nmsg.payload = [id];\nreturn msg;",
