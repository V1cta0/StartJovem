        "id": "verificarDuplicata",
        "type": "function",
        "z": "48a2a193d2a3bd81",
        "name": "Verificar Duplicata",
        "func": "const { turma_id, aprendiz_id } = msg.payload;\n\nif (!turma_id || !aprendiz_id) {\n    msg.payload = { sucesso: false, mensagem: \"Turma e Aprendiz são obrigatórios\" };\n    return msg;\n}\n\n// Verifica se já existe vínculo\nmsg.topic = `SELECT COUNT(*) as total FROM turma_aprendizes WHERE turma_id = ? AND aprendiz_id = ?`;\nmsg.payload = [turma_id, aprendiz_id];\n\nreturn msg;",
