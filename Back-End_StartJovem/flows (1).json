        "z": "c6c1498fd7368b4d",
        "name": "Salvar Produtividade",
        "func": "const { aprendiz_id, dia_semana, minutos } = msg.payload;\nconst dias = ['Segunda', 'Terça', 'Quarta', 'Quinta', 'Sexta', 'Sábado', 'Domingo'];\nconst diaNome = dias[dia_semana];\nconst hoje = new Date().toISOString().split('T')[0];\n\nmsg.topic = \"INSERT INTO produtividade (aprendiz_id, dia_semana, minutos, data_registro) VALUES (?, ?, ?, ?) ON DUPLICATE KEY UPDATE minutos = ?\";\nmsg.payload = [aprendiz_id, diaNome, minutos, hoje, minutos];\nreturn msg;",
