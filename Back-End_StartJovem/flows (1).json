    {
        "id": "decidirAcao",
        "type": "function",
        "z": "48a2a193d2a3bd81",
        "name": "Decidir Ação (Duplicata?)",
        "func": "const count = msg.payload[0] ? msg.payload[0].total : 0;\n\nif (count > 0) {\n    // Já existe\n    msg.payload = {\n        sucesso: false,\n        mensagem: \"⚠️ Este aprendiz já está vinculado nesta turma!\"\n    };\n    return [msg, null];\n}\n\n// Pode inserir\nmsg.topic = `INSERT INTO turma_aprendizes (turma_id, aprendiz_id) VALUES (?, ?)`;\nmsg.payload = [msg.req.body.turma_id || msg.payload.turma_id, msg.req.body.aprendiz_id || msg.payload.aprendiz_id];\n\nreturn [null, msg];",
